# ─── Modo sem Lambda (auth local) ───────────────────
# Deixe assim para testar sem AWS
LAMBDA_FUNCTION_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── Modo com Lambda real ────────────────────────────
# Descomente e preencha para usar seu Lambda de autorização
# LAMBDA_FUNCTION_NAME=atm-auth-authorizer
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ─── Flask ───────────────────────────────────────────
FLASK_DEBUG=0
